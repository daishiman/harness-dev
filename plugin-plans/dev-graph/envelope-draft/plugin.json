{
  "name": "dev-graph",
  "version": "0.1.0",
  "description": "ローカルtask graph/Markdownを正本に仕様成果物を一元管理し、BeadsまたはGitHubへbinding別投影しながら要件定義・実装handoff・複数worktree実行・PR完了収束を担う管理ハーネスのmanifest draft。",
  "author": {
    "name": "xl-skills maintainers"
  },
  "entry_points": {
    "skills": [
      "run-dev-graph-init",
      "run-dev-graph-node",
      "run-dev-graph-sync",
      "run-dev-graph-requirements",
      "run-dev-graph-render",
      "run-dev-graph-decompose",
      "run-dev-graph-schedule",
      "run-dev-graph-status",
      "run-dev-graph-system-spec"
    ],
    "agents": [
      "dev-graph-integrity-auditor",
      "dev-graph-sync-conflict-verifier",
      "dev-graph-requirements-verifier",
      "dev-graph-parallel-safety-verifier"
    ],
    "hooks": [
      "guard-graph-schema",
      "reconcile-task-lifecycle"
    ],
    "commands": [
      "dev-graph"
    ]
  },
  "depends_on": [
    "system-spec-harness",
    "system-dev-planner"
  ],
  "dependency_contracts": {
    "system-spec-harness": {
      "version_range": ">=0.1.0 <1.0.0",
      "required_entry_points": ["run-system-spec-elicit", "run-system-spec-doc-fetch", "run-system-spec-compile", "assign-system-spec-completeness-evaluator"],
      "failure_policy": "fail-closed with diagnostic; no local compiler fallback"
    },
    "system-dev-planner": {
      "version_range": ">=0.1.0 <1.0.0",
      "required_entry_points": ["run-system-dev-plan", "system-dev-plan-architect", "system-dev-plan-evaluator", "validate-system-plan.py"],
      "failure_policy": "fail-closed; dev-graph owns no duplicate entry point"
    },
    "plugin-dev-planner": {
      "relation": "design-contract-reference",
      "version_range": ">=0.1.0 <1.0.0"
    }
  },
  "runtime_context": {
    "distribution": "symbolic-link-supported",
    "code_authority": "$CLAUDE_PLUGIN_ROOT",
    "content_authority": "$CLAUDE_PROJECT_DIR",
    "content_boundary": "$CLAUDE_PROJECT_DIR",
    "repo_config": ".dev-graph/config.json",
    "root_precedence": ["--repo-root", "trusted-project-environment", "git-toplevel", "cwd-marker"],
    "candidate_acceptance": "realpath(resolved_repo_root) == realpath($CLAUDE_PROJECT_DIR)",
    "resolved_root_export": "DEV_GRAPH_REPO_ROOT",
    "coordination_authority": "$GIT_COMMON_DIR/dev-graph",
    "coordination_boundary": "ephemeral leases/events/cache only; no content, graph, secret, or absolute worktree path",
    "stored_paths": "repository-relative",
    "outside_repository": "deny"
  },
  "permissions": {
    "network": [],
    "filesystem": ["$CLAUDE_PLUGIN_ROOT/**", "$CLAUDE_PROJECT_DIR/.dev-graph/**", "$CLAUDE_PROJECT_DIR/issues/**", "$CLAUDE_PROJECT_DIR/tasks/**", "$CLAUDE_PROJECT_DIR/specs/**", "$CLAUDE_PROJECT_DIR/architecture/**", "$CLAUDE_PROJECT_DIR/docs/**", "$CLAUDE_PROJECT_DIR/system-spec/**", "$GIT_COMMON_DIR/dev-graph/**"],
    "secrets": []
  },
  "distributable": false,
  "bundle_targets": [],
  "category": "developer-tools",
  "tags": [
    "task-graph",
    "github",
    "dev-graph",
    "task-decomposition",
    "scheduling"
  ]
}
