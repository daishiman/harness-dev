  "workstream_kinds": ["frontend", "backend", "api", "data", "infrastructure", "security", "quality", "documentation", "operations"],
  "required_outputs": ["feature-package.json", "exactly 13 executable phase task specifications", "workstream-inventory.json with P01..P13 exact-set", "13-node task-graph projection", "system-build handoff draft", "four-condition evaluation", "atomic promotion receipt"],
  "normalization": {
    "lifecycle_axis": "P01..P13 fixed slots",
    "workstream_axis": "each of the 13 tasks has one primary workstream and optional secondary workstreams",
    "execution_axis": "the same 13 task specs are the executable DAG nodes",
    "rule": "do not emit separate lifecycle documents plus N tasks; emit exactly one executable task spec per phase slot"
