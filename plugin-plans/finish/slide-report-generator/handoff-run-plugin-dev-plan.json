  "open_issues": [
    {
      "id": "GAP-ENVELOPE-001",
      "severity": "high",
      "text": "plugin envelope executor (manifest/marketplace scaffold) is external to run-plugin-dev-plan",
      "resolution_condition": "plugin-scaffold 実行実体 (または人手 scaffold 手順) が envelope-draft/plugin.json を plugins/slide-report-generator/.claude-plugin/plugin.json へ適用して validate_plugin 相当検査が exit 0、かつ surface_tasks S-VENDOR/S-COMPOSITION の checks が全 PASS した build trace が記録された時点で closed"
    },
    {
      "id": "GAP-SCRIPT-BUILDER",
      "severity": "high",
      "text": "plugin-scaffold は contract-only builder 語彙で単独実行実体が未整備 (共有 script C23 の plugin-root hoist・当面は run-build-skill の build フロー内で代替生成)",
      "resolution_condition": "specfm.BUILDER_STATUS の plugin-scaffold が executor-backed へ昇格 (専用 executor 整備) する、または routes[C23].fallback_builder=run-build-skill で C23 が生成され lint-script-frontmatter + tests_min>=80 PASS の build trace が記録された時点で closed"
    }
  ]
