  "surface_tasks_note": "plugin_level_surfaces の surface 実体 (vendor byte copy / schemas 新設 / references / composition / EVALS) の build route。routes[] は component-inventory.json の components[] と 1:1 (inventory 由来検証) のため surface を routes へ混ぜず、本配列で owner_builder/build_args/build_target/checks/実行順序を宣言する。routes[].requires_surfaces が component→surface の順序依存を宣言する (S-VENDOR は requires_surfaces 宣言 route より先に実行)",
  "surface_tasks": [
    {
      "id": "S-VENDOR",
      "surface": "vendor",
      "order": 1,
      "sequencing": "pre-routes (requires_surfaces:[\"S-VENDOR\"] を宣言する全 route より先に実行)",
      "owner_builder": "plugin-scaffold",
      "builder_status": "contract-only",
      "gap_ref": "GAP-SCRIPT-BUILDER",
      "build_target": "plugins/slide-report-generator/vendor/",
      "build_args": {
        "copy_mode": "whole-tree",
        "source_digest_manifest": "vendor-digest-manifest.json",
        "subtrees": [
          "scripts/ → vendor/scripts/",
          "assets/ → vendor/assets/",
          "schemas/ → vendor/schemas-fixtures/",
          "package.json / package-lock.json → vendor/"
        ],
        "post_copy": [
          "npm ci (package-lock.json pinned で node_modules を再install・node_modules は byte copy しない)",
          "npx playwright install chromium (render/verify 系のヘッドレス実行前提)"
        ]
      },
      "checks": [
        "lint-vendor-parity.py (build 時に plugin scripts/ へ同梱・plan 段階では契約のみ) が copy 直後の vendor 実体を vendor-digest-manifest.json (sha256・195 files pinned・upstream presentation-slide-generator v8.4.2) と全件照合し exit 0",
        "npm ci が exit 0 で node_modules を lock どおり再構成し、npx playwright install が完了する",
        "additive (render-report.js/mermaid-render.js/package.json mermaid 依存追記) は照合の明示除外 (inventory vendor.parity_scope 準拠・別検査)"
      ]
    },
    {
      "id": "S-SCHEMAS",
      "surface": "schemas",
      "order": 2,
      "sequencing": "post-S-VENDOR (byte copy 済 schemas-fixtures への additive 新設)",
      "owner_builder": "run-build-skill",
      "requires_surfaces": [
        "S-VENDOR"
      ],
      "build_target": "plugins/slide-report-generator/vendor/schemas-fixtures/report-structure.schema.json",
      "build_args": {
        "new_files": [
          "report-structure.schema.json (新設・4 reportType 骨格)"
        ],
        "record_in": "index.plugin_meta"
      },
      "checks": [
        "移植 4 schema + example fixture 3 + README は S-VENDOR byte copy 済であること (二重作業・二重 SSOT 禁止)",
        "report-structure.schema.json が JSON parse 可能で structure.schema.json と共通コア (nodes/edges/groups/theme/aiVisual) を共有する",
        "index.plugin_meta の schema 記録が真 schema 5 本 (4 移植 + 1 新設) と一致する"
      ]
    },
    {
      "id": "S-REFERENCES",
      "surface": "references_config_assets",
      "order": 3,
      "sequencing": "post-S-VENDOR (pointer_only 項目の byte 実体が vendor に在ることを前提)",
      "owner_builder": "run-build-skill",
      "requires_surfaces": [
        "S-VENDOR"
      ],
      "build_target": "plugins/slide-report-generator/references/",
      "build_args": {
        "byte_copy": "既存 42 references (*.md・upstream presentation-slide-generator v8.4.2) を byte 維持で携行 (本 surface が byte 正本)",
        "new_files": [
          "report-types.md",
          "report-writing-rules.md",
          "report-visual-strategy.md",
          "mermaid-integration.md"
        ],
        "pointer_only": "118 templates/pagination/print-styles.css/style-genome/d3-components/gas-deploy-guide.md の byte 実体は S-VENDOR が携行 (相互参照ポインタのみ・二重 SSOT 禁止)"
      },
      "checks": [
        "既存 42 references が移植元と byte 一致する",
        "report 新規 4 references が新設され既存 42 と重複しない",
        "pointer_only 項目の byte 実体を references 側へ複製していない"
      ]
    },
    {
      "id": "S-COMPOSITION",
      "surface": "composition",
      "order": 4,
      "sequencing": "post-routes (全 23 component route の build 完了後に合成配線)",
      "owner_builder": "plugin-scaffold",
      "builder_status": "contract-only",
      "gap_ref": "GAP-ENVELOPE-001",
      "build_target": "plugins/slide-report-generator/plugin-composition.yaml",
      "build_args": {
        "contents": "skills 3 / agents 16 / commands 2 / hook 1 / plugin-root script 1 の合成配線 (routes C01..C23 と 1:1)"
      },
      "checks": [
        "列挙 component が routes の 23 実体と過不足なく一致する",
        "hook 配線の正本は plugin manifest (envelope hooks ブロック) であり、composition からは settings.json 配線を宣言しない (inventory C20.settings_wiring=plugin-manifest と整合)"
      ]
    },
    {
      "id": "S-EVALS",
      "surface": "harness_eval",
      "order": 5,
      "sequencing": "post-routes (受入配線は build 済み成果物実体を参照)",
      "owner_builder": "run-build-skill",
      "build_target": "plugins/slide-report-generator/EVALS.json",
      "build_args": {
        "modes": [
          "slide",
          "report"
        ],
        "kinds": [
          "mechanical",
          "llm_eval"
        ]
      },
      "checks": [
        "mechanical + llm_eval が slide/report 両モードの受入を配線する",
        "EVALS.json が JSON parse 可能で harness coverage >=80 の受入基準を参照する"
      ]
    }
  ],
