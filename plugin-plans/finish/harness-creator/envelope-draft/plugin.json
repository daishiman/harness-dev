{
  "name": "harness-creator",
  "distributable": false,
  "version": "1.1.0",
  "description": "Claude Code Òü«ÒâÅÒâ╝ÒâìÒé╣ ÔÇö Capability (Skill / Agent / Hook / Command / Plugin-Composition / Prompt / Workflow) Òü¿Þ®òõ¥íÒâ╗þÁ▒µ▓╗µ®ƒµºïÒü«þÀÅõ¢ô ÔÇö ÒéÆµºïþ»ëÒâ╗Þ®òõ¥íÒâ╗þÁ▒µ▓╗ÒüÖÒéïÒâíÒé┐ÒâùÒâ®Òé░ÒéñÒâ│ÒÇéÕìÿõ¢ôÒé╣Òé¡Òâ½þöƒµêÉÒü»Úâ¿ÕôüÕìÿõ¢ìÒü«Þâ¢ÕèøÒü¿ÒüùÒüªÕåàÕîàÒüÖÒéï",
  "author": {
    "name": "xl-skills maintainers"
  },
  "requirements": {
    "external_clis": [
      {
        "name": "tmux",
        "reason": "live-trial Þ╝©ÚÇüÕ▒ñ(ÕêÑÒâùÒâ¡Òé╗Òé╣µ£¼þë®claudeÒé╗ÒââÒéÀÒâºÒâ│Òü«paneÕêÂÕ¥í)ÒÇéPython stdlibõ╗úµø┐õ©ìÞâ¢ÒÇéõ©ìÕ£¿µÖéÒü»live-trial verdict=BLOCKEDÒüºfail-closed",
        "required_for": ["run-skill-live-trial"]
      }
    ]
  },
  "entry_points": {
    "skills": [
      "run-plugin-dev-plan",
      "run-skill-create"
    ],
    "commands": [
      "plugin-dev-plan",
      "capability-build"
    ],
    "agents": [
      "plugin-dev-plan-improvement-reviewer"
    ]
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "matcher": ".*",
        "hooks": [
          { "type": "command", "command": "python3 $CLAUDE_PLUGIN_ROOT/skills/run-skill-update-notifier/scripts/hook-cache-refresh.py" },
          { "type": "command", "command": "python3 $CLAUDE_PLUGIN_ROOT/skills/ref-task-context-map/scripts/preload-context-map.py", "timeout": 3000 }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          { "type": "command", "command": "python3 $CLAUDE_PLUGIN_ROOT/skills/wrap-git-commit-safe/scripts/preflight-git-commit.py", "timeout": 4000 }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Skill",
        "hooks": [
          { "type": "command", "command": "python3 $CLAUDE_PLUGIN_ROOT/skills/run-skill-update-notifier/scripts/hook-notify-skill-end.py" },
          { "type": "command", "command": "python3 $CLAUDE_PLUGIN_ROOT/skills/run-build-skill/scripts/auto-record-lesson.py", "timeout": 5000 },
          { "type": "command", "command": "python3 $CLAUDE_PLUGIN_ROOT/skills/run-elegant-review/scripts/check-review-trigger.py", "timeout": 3000 }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          { "type": "command", "command": "python3 $CLAUDE_PLUGIN_ROOT/skills/run-build-skill/scripts/lint-capability-manifest.py", "timeout": 5000 },
          { "type": "command", "command": "python3 $CLAUDE_PLUGIN_ROOT/skills/run-elegant-review/scripts/check-review-trigger.py", "timeout": 3000 }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          { "type": "command", "command": "python3 $CLAUDE_PLUGIN_ROOT/skills/run-skill-rubric-governance/scripts/diff-rubric-impact.py", "timeout": 5000 }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": ".*",
        "hooks": [
          { "type": "command", "command": "python3 $CLAUDE_PLUGIN_ROOT/skills/run-elegant-review/scripts/check-review-trigger.py", "timeout": 3000 }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": ".*",
        "hooks": [
          { "type": "command", "command": "python3 $CLAUDE_PLUGIN_ROOT/skills/run-skill-rubric-governance/scripts/aggregate-evals.py", "timeout": 10000 }
        ]
      }
    ]
  }
}
