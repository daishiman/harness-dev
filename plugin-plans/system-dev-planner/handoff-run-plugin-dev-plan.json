  "runtime_contract": {
    "distribution_mode": "symlink",
    "content_authority": "caller-repository",
    "root_precedence": [
      "--repo-root",
      "trusted-project-env",
      "git-rev-parse-show-toplevel",
      "cwd-dev-graph-marker"
    ],
    "config_path": ".dev-graph/config.json",
    "path_policy": "repo-relative + realpath containment; absolute/traversal/symlink escape/cross-repo denied",
    "plugin_source_policy": "$CLAUDE_PLUGIN_ROOT locates code/assets only",
    "state_isolation": "state/cache/lock/staging/published are per caller repository",
    "init_policy": "idempotent-create-missing-only; never overwrite repository content",
    "promotion": "same staging/evaluator digest + readiness complete + all gates PASS, then atomic rename in same repository filesystem",
    "dev_graph_registration_ref": "dev-graph-registration-contract.json"
  },
