      }
    ],
    "recommended": [
      {
        "id": "ai-disclaimer",
        "name": "AI利用に関する説明・免責",
        "weight": 0.9,
        "condition": "business.useAI === true"
      },
      {
        "id": "appendix-conditions",
        "name": "取引条件明示書",
        "weight": 1.0,
        "condition": "freelance === true"
      }
    ]
  }
}
