{
  "_build_claude_settings": {
    "managed_hooks": [
      {
        "event": "PreToolUse",
        "matcher": "Bash",
        "command": "python3 ${CLAUDE_PROJECT_DIR}/plugins/contract-generator/hooks/hook-guard-secret.py",
        "from_plugin": "contract-generator"
      },
      {
        "event": "PostToolUse",
        "matcher": "Edit",
        "command": "python3 ${CLAUDE_PROJECT_DIR}/plugins/harness-creator/skills/run-skill-rubric-governance/scripts/diff-rubric-impact.py",
        "from_plugin": "harness-creator"
      },
      {
        "event": "PostToolUse",
        "matcher": "Edit|Write",
        "command": "python3 ${CLAUDE_PROJECT_DIR}/plugins/harness-creator/skills/run-build-skill/scripts/lint-capability-manifest.py",
        "from_plugin": "harness-creator"
      },
      {
        "event": "PostToolUse",
        "matcher": "Edit|Write",
        "command": "python3 ${CLAUDE_PROJECT_DIR}/plugins/harness-creator/skills/run-elegant-review/scripts/check-review-trigger.py",
        "from_plugin": "harness-creator"
      },
      {
        "event": "PostToolUse",
        "matcher": "Skill",
        "command": "python3 ${CLAUDE_PROJECT_DIR}/plugins/harness-creator/skills/run-build-skill/scripts/auto-record-lesson.py",
        "from_plugin": "harness-creator"
      },
      {
        "event": "PostToolUse",
        "matcher": "Skill",
