{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://harness/run-build-skill/schemas/responsibility-slot.schema.json",
  "title": "Responsibility Slot",
  "description": "R-id 単位の prompt slot 形式。frontmatter.responsibility_refs から参照され、prompts/<R-id>.md (既定) または prompts/<R-id>.yaml (legacy) の 7 層プロンプト位置を確定する。",
  "type": "object",
  "additionalProperties": false,
  "required": ["r_id", "owner", "layers", "prompt_path"],
  "properties": {
    "r_id": {"type": "string", "pattern": "^R[0-9]+$"},
    "owner": {"type": "string", "enum": ["Skill", "Subagent", "Hook"]},
    "title": {"type": "string"},
    "layers": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "enum": ["L1", "L2", "L3", "L4", "L5", "L6", "L7"]}
    },
    "prompt_path": {"type": "string", "pattern": "^prompts/R[0-9]+(-[a-z0-9]+(-[a-z0-9]+)*)?\\.(md|yaml)$"},
    "self_evaluation_required": {"type": "boolean", "default": true},
    "expected_output_schema": {"type": "string"},
    "context_inputs": {
      "type": "array",
      "items": {"type": "string"}
    }
  }
}
