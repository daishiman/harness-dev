{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://harness/run-build-skill/schemas/verification-evidence.schema.json",
  "title": "Verification Evidence Receipt",
  "description": "obligation fingerprintに束縛した内容アドレス証拠。入力または依存claimが変われば再利用不能になる。",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "subject", "obligation_id", "fingerprint_sha256", "status", "confidence", "verifier", "evidence", "finding_codes", "produced_at"],
  "properties": {
    "schema_version": {"const": 1},
    "subject": {"type": "string", "minLength": 1},
    "obligation_id": {"type": "string", "minLength": 1},
    "fingerprint_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "status": {"type": "string", "enum": ["PASS", "FAIL", "INCONCLUSIVE"]},
    "confidence": {"type": "number", "minimum": 0, "maximum": 1},
    "verifier": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "id"],
      "properties": {
        "kind": {"type": "string", "enum": ["deterministic", "llm", "live", "human"]},
        "id": {"type": "string", "minLength": 1}
      }
    },
    "evidence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "sha256"],
        "properties": {
          "path": {"type": "string", "minLength": 1},
          "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
        }
      }
    },
    "finding_codes": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
    "run_id": {"type": "string", "minLength": 1, "description": "同一command invocationの累積model-action/usage budget join key。"},
    "model_action_id": {"type": "string", "minLength": 1, "description": "1 model contextが複数obligation receiptを生成した場合の重複課金防止join key。"},
    "usage": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "input_tokens": {"type": "integer", "minimum": 0},
        "output_tokens": {"type": "integer", "minimum": 0},
        "elapsed_ms": {"type": "integer", "minimum": 0},
        "estimated_cost_usd": {"type": "number", "minimum": 0}
      }
    },
    "note": {"type": "string"},
    "produced_at": {"type": "string", "minLength": 1}
  }
}
