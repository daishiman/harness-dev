{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://harness/run-build-skill/schemas/knowledge-loop.schema.json",
  "title": "KnowledgeLoop",
  "description": "knowledge-loop capability の全構造定義。エントリ・index・router・scoring_weights・usage-log エントリを含む。",

  "definitions": {
    "KnowledgeEntry": {
      "type": "object",
      "description": "ナレッジエントリ。必須6フィールド (id/title|content/intent|purpose/background/keywords|tags/source) を持つ。",
      "required": ["id", "background", "source"],
      "allOf": [
        {
          "anyOf": [
            {"required": ["title"]},
            {"required": ["content"]}
          ]
        },
        {
          "anyOf": [
            {"required": ["intent"]},
            {"required": ["purpose"]}
          ]
        },
        {
          "anyOf": [
            {"required": ["keywords"]},
            {"required": ["tags"]}
          ]
        }
      ],
      "properties": {
        "id": {
          "type": "string",
          "description": "一意識別子。{category}_{3桁連番} 形式推奨。",
          "minLength": 3
        },
        "title": {
          "type": "string",
          "description": "知識の核心。主語+動詞+目的語の1文。修飾語2つまで。",
          "minLength": 5
        },
        "content": {
          "type": "string",
          "description": "知識の核心 (title の代替)。",
          "minLength": 5
        },
        "intent": {
          "type": "string",
          "description": "「〜すること」「〜を防ぐこと」の形で記述。before→after が読み取れること。",
          "minLength": 5
        },
        "purpose": {
          "type": "string",
          "description": "intent の代替。",
          "minLength": 5
        },
        "background": {
          "type": "string",
          "description": "業種・規模・期間・数値のうち最低2つを含む。2〜5文。",
          "minLength": 10
        },
        "keywords": {
          "type": "array",
          "description": "悩みワード+同義語+上位語で5〜8語推奨。",
          "items": {"type": "string"},
          "minItems": 3
        },
        "tags": {
          "type": "array",
          "description": "keywords の代替。",
          "items": {"type": "string"},
          "minItems": 3
        },
        "source": {
          "description": "出典情報。ファイル名+種別+日付+セクションを含む形式推奨。",
          "oneOf": [
            {"type": "string", "minLength": 1},
            {
              "type": "object",
              "required": ["file", "type"],
              "properties": {
                "file": {"type": "string"},
                "type": {"type": "string"},
                "date": {"type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"},
                "section": {"type": "string"}
              },
              "additionalProperties": false
            }
          ]
        },
        "message": {"type": "string"},
        "root_cause": {"type": "string"},
        "expected_outcome": {
          "oneOf": [{"type": "string"}, {"type": "array", "items": {"type": "string"}}]
        },
        "achievable": {
          "oneOf": [{"type": "string"}, {"type": "array", "items": {"type": "string"}}]
        },
        "how_to_use": {"type": "string"},
        "applications": {"type": "string"},
        "future": {"type": "string"},
        "related_items": {"type": "array", "items": {"type": "string"}},
        "related": {"type": "array", "items": {"type": "string"}},
        "output_types": {"type": "array", "items": {"type": "string"}},
        "action_items": {"type": "array", "items": {"type": "string"}},
        "status": {
          "type": "string",
          "enum": ["pending", "processed", "needs-update", "deprecated"]
        },
        "deprecated_reason": {"type": "string"},
        "deprecated_date": {"type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"},
        "quote": {"type": "array", "items": {"type": "string"}},
        "sakamoto_expressions": {"type": "array", "items": {"type": "string"}},
        "sakamoto_voice": {"type": "string"}
      },
      "additionalProperties": true
    },

    "ScoringWeights": {
      "type": "object",
      "description": "フィールド重み付きスコアリングの重み設定。",
      "properties": {
        "title": {"type": "number", "minimum": 0, "default": 5},
        "keywords": {"type": "number", "minimum": 0, "default": 3},
        "quote": {"type": "number", "minimum": 0, "default": 2},
        "voice": {"type": "number", "minimum": 0, "default": 2},
        "fulltext": {"type": "number", "minimum": 0, "default": 1}
      },
      "additionalProperties": false
    },

    "KnowledgeIndex": {
      "type": "object",
      "description": "Index-Search型 knowledge-index.json の構造。",
      "required": ["version", "categories", "consult_at"],
      "properties": {
        "version": {"type": "string"},
        "categories": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "label", "file"],
            "properties": {
              "id": {"type": "string"},
              "label": {"type": "string"},
              "file": {"type": "string"},
              "keywords": {"type": "array", "items": {"type": "string"}}
            },
            "additionalProperties": false
          }
        },
        "global_keywords": {
          "type": "object",
          "additionalProperties": {"type": "array", "items": {"type": "string"}}
        },
        "synonyms": {
          "type": "object",
          "additionalProperties": {"type": "array", "items": {"type": "string"}}
        },
        "scoring_weights": {"$ref": "#/definitions/ScoringWeights"},
        "output_dir": {"type": "string"},
        "output_naming": {"type": "string"},
        "_comment": {"type": "string"},
        "description": {"type": "string"},
        "pattern": {"type": "string", "enum": ["index-search", "router-registry"]},
        "usage_log": {"type": "string"},
        "consult_at": {
          "type": "array",
          "description": "このストアを誰がいつ参照するか (Loop 種別と物理位置の機械可読な根拠)。Loop A=[\"runtime\"] / Loop B=[\"build-time\"]。lint KL-007 が物理位置との一致を強制する。",
          "items": {"type": "string", "enum": ["runtime", "build-time"]},
          "minItems": 1
        },
        "consult_note": {"type": "string"},
        "lifecycle": {
          "type": "object",
          "properties": {
            "split_threshold_lines": {"type": "integer", "minimum": 1},
            "split_threshold_entries": {"type": "integer", "minimum": 1}
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },

    "RouterJson": {
      "type": "object",
      "description": "Router-Registry型 router.json の構造。",
      "required": ["categories", "consult_at"],
      "properties": {
        "consult_at": {
          "type": "array",
          "description": "このストアを誰がいつ参照するか (Loop 種別と物理位置の機械可読な根拠)。Loop A=[\"runtime\"] / Loop B=[\"build-time\"]。lint KL-007 が物理位置との一致を強制する。",
          "items": {"type": "string", "enum": ["runtime", "build-time"]},
          "minItems": 1
        },
        "categories": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "required": ["files", "routing_rules"],
            "properties": {
              "files": {"type": "array", "items": {"type": "string"}},
              "routing_rules": {
                "type": "object",
                "additionalProperties": {
                  "type": "object",
                  "required": ["topic", "tags", "default"],
                  "properties": {
                    "topic": {"type": "string"},
                    "tags": {"type": "array", "items": {"type": "string"}},
                    "default": {"type": "boolean"}
                  },
                  "additionalProperties": false
                }
              }
            },
            "additionalProperties": false
          }
        },
        "quick_lookup": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "additionalProperties": {
              "type": "object",
              "properties": {
                "files": {"type": "array", "items": {"type": "string"}}
              }
            }
          }
        }
      },
      "additionalProperties": false
    },

    "RegistryEntry": {
      "type": "object",
      "description": "registry.json の1エントリ。ソース素材の処理状況を追跡する。",
      "required": ["path", "source_type", "status"],
      "properties": {
        "path": {"type": "string"},
        "source_type": {"type": "string", "enum": ["youtube", "markdown", "pdf", "text", "other"]},
        "status": {"type": "string", "enum": ["pending", "processed", "needs-update", "deprecated"]},
        "file_hash": {"type": "string"},
        "file_modified": {"type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"},
        "processed_date": {"type": "string"},
        "entries_extracted": {"type": "integer", "minimum": 0},
        "extracted_entry_ids": {"type": "array", "items": {"type": "string"}},
        "target_categories": {"type": "array", "items": {"type": "string"}},
        "deprecated_reason": {"type": "string"},
        "deprecated_date": {"type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"}
      },
      "additionalProperties": false
    },

    "UsageLogEntry": {
      "type": "object",
      "description": "usage-log.jsonl の1行。Stage2マッチ結果とAI活用状況を記録する。",
      "required": ["timestamp", "query", "matched_ids", "used_ids", "satisfaction"],
      "properties": {
        "timestamp": {"type": "string", "format": "date-time"},
        "query": {"type": "string"},
        "matched_ids": {"type": "array", "items": {"type": "string"}},
        "used_ids": {"type": "array", "items": {"type": "string"}},
        "satisfaction": {"type": "string", "enum": ["helpful", "neutral", "unhelpful"]},
        "note": {"type": "string"}
      },
      "additionalProperties": false
    }
  },

  "oneOf": [
    {"$ref": "#/definitions/KnowledgeEntry"},
    {"$ref": "#/definitions/KnowledgeIndex"},
    {"$ref": "#/definitions/RouterJson"},
    {"$ref": "#/definitions/RegistryEntry"},
    {"$ref": "#/definitions/UsageLogEntry"}
  ]
}
