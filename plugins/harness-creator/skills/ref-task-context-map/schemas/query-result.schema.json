{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "ref-task-context-map/schemas/query-result.schema.json",
  "title": "TaskContextMapQueryResult",
  "type": "object",
  "required": ["matches"],
  "properties": {
    "matches": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path", "excerpt", "score"],
        "properties": {
          "path": { "type": "string", "description": "ヒットした references/ 内のパス" },
          "excerpt": { "type": "string", "description": "該当箇所の原文抜粋" },
          "score": { "type": "number", "description": "マッチ強度 (0.0-1.0)" },
          "chapter_refs": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["chapter", "path"],
              "properties": {
                "chapter": { "type": "string", "description": "章番号 (例 03 / 22)" },
                "path": { "type": "string", "description": "設計書ファイルパス" }
              }
            }
          }
        }
      }
    },
    "suggestions": {
      "type": "array",
      "items": { "type": "string" },
      "description": "該当ゼロ時の近傍 trigger 候補"
    }
  }
}
