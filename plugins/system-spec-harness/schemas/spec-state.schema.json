{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://harness/schemas/system-spec-state.json",
  "title": "system-spec canonical elicitation state",
  "type": "object",
  "required": [
    "schema_version",
    "categories",
    "platforms",
    "matrix",
    "category_aggregate",
    "requirements_foundation",
    "qa_log",
    "approval_log",
    "reopen_log",
    "targets"
  ],
  "properties": {
    "schema_version": {"type": "string", "minLength": 1},
    "categories": {"type": "array", "minItems": 1},
    "platforms": {"type": "array", "minItems": 1},
    "matrix": {"type": "object"},
    "category_aggregate": {"type": "object"},
    "requirements_foundation": {"type": "object"},
    "qa_log": {"type": "array"},
    "approval_log": {"type": "array"},
    "reopen_log": {"type": "array"},
    "targets": {"type": "array"},
    "decisions": {"type": "array"},
    "knowledge_candidates": {"type": "array"},
    "hearing_progress": {"type": "object"}
  },
  "additionalProperties": true
}
