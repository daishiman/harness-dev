{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "knowledge-card.schema.json",
  "title": "System Design Knowledge Card",
  "type": "object",
  "required": [
    "knowledge_id", "title", "status", "purpose", "background", "problems",
    "core_concepts", "applies_when", "does_not_apply_when", "tradeoffs",
    "failure_modes", "goal_contribution", "primary_sources", "freshness"
  ],
  "properties": {
    "knowledge_id": {"type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"},
    "title": {"type": "string", "minLength": 3},
    "status": {"enum": ["seed-example", "project-candidate", "curated", "stale", "retired"]},
    "purpose": {"type": "string", "minLength": 20},
    "background": {"type": "string", "minLength": 20},
    "problems": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 10}},
    "core_concepts": {"type": "array", "minItems": 2, "items": {"type": "string", "minLength": 10}},
    "applies_when": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 10}},
    "does_not_apply_when": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 10}},
    "tradeoffs": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 10}},
    "failure_modes": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 10}},
    "goal_contribution": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 10}},
    "primary_sources": {
      "type": "array", "minItems": 1,
      "items": {
        "type": "object", "required": ["title", "publisher_or_author", "locator"],
        "properties": {
          "title": {"type": "string"}, "publisher_or_author": {"type": "string"},
          "locator": {"type": "string"}, "published_or_updated": {"type": "string"}
        }, "additionalProperties": false
      }
    },
    "freshness": {
      "type": "object", "required": ["class", "last_checked", "review_by", "triggers"],
      "properties": {
        "class": {"enum": ["foundational-stable", "standard-tracked", "vendor-tracked", "stale"]},
        "last_checked": {"type": "string", "format": "date"},
        "review_by": {"type": "string", "format": "date"},
        "triggers": {"type": "array", "minItems": 1, "items": {"type": "string"}}
      }, "additionalProperties": false
    },
    "related_topics": {"type": "array", "items": {"type": "string"}}
  },
  "additionalProperties": false
}

