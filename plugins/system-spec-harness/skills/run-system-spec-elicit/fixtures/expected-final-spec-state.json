  "qa_log": [
    {
      "id": "qa-001",
      "question": "データベース（database）× Web の要件は?",
      "answer": "PostgreSQL 15。ユーザー/請求/監査ログの3スキーマ。日次バックアップ。"
    },
    {
      "id": "qa-002",
      "question": "認証(ログイン)（auth）× Web の要件は?",
      "answer": "OIDC(社内 IdP)+ ロールベース認可。セッションは 8h。"
    },
    {
      "id": "qa-003",
      "question": "UI-UX（ui-ux）× Web の要件は?",
      "answer": "レスポンシブ Web。WCAG 2.1 AA 目標。主要動線は3クリック以内。"
    },
    {
      "id": "qa-004",
      "question": "セキュリティ（security）× Web の要件は?",
      "answer": "TLS1.3・入力検証・監査ログ・OWASP Top10 受動対策。"
    },
    {
      "id": "qa-005",
      "question": "インフラ（infrastructure）× Web の要件は?",
      "answer": "コンテナを社内 k8s にデプロイ。CI/CD は GitHub Actions。"
    },
    {
      "id": "qa-006",
      "question": "バックエンド（backend）× Web の要件は?",
      "answer": "Python/FastAPI。REST + 非同期ジョブ(キュー)。"
    },
    {
      "id": "qa-007",
      "question": "フロントエンド（frontend）× Web の要件は?",
      "answer": "React + TypeScript。状態管理は最小限のグローバルストア。"
    },
    {
      "id": "qa-008",
      "question": "保守運用管理（maintenance-ops）× Web の要件は?",
      "answer": "オンコール輪番・障害 runbook・週次リストア訓練。"
    }
  ],
