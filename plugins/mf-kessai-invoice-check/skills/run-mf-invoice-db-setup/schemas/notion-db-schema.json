{
  "title": "請求書発行チェック（マネーフォワード掛け払い）",
  "description": "発行漏れチェック結果の出力先DB。1顧客=1ページ(顧客ID集約)。DBプロパティは最新月スナップショット、月次履歴はページ本文の table block に蓄積。事実列(API由来)と管理列(人の運用)を分離する。",
  "properties": {
    "取引先企業名": {"type": "title"},
    "顧客ID": {"type": "rich_text"},
    "対象年月": {"type": "rich_text"},
    "今月の発行状況": {"type": "select", "options": ["発行漏れ候補", "継続発行", "今月新規"]},
    "商品名": {"type": "rich_text"},
    "前月金額": {"type": "number"},
    "今月金額": {"type": "number"},
    "発行日": {"type": "date"},
    "更新日": {"type": "date"},
    "確認済み日時": {"type": "date"},
    "初回契約月": {"type": "rich_text"},
    "請求要否": {"type": "select", "options": ["継続", "今月のみ不要", "契約終了"]},
    "支払サイクル": {"type": "select", "options": ["月払い", "年間払い"]},
    "チェック済": {"type": "checkbox"},
    "備考": {"type": "rich_text"}
  },
  "fact_columns": ["取引先企業名", "顧客ID", "対象年月", "今月の発行状況", "商品名", "前月金額", "今月金額", "発行日", "更新日", "確認済み日時"],
  "managed_columns": ["初回契約月", "請求要否", "支払サイクル", "チェック済", "備考"],
  "upsert_key": ["顧客ID"],
  "renames": {"判定": "今月の発行状況"},
  "deprecated_properties": ["レコード種別", "発行漏れ件数", "金額変動件数", "チェック件数合計", "全体トータル", "対応状況", "チェック実行ID", "初回請求月(API推定)"]
}
