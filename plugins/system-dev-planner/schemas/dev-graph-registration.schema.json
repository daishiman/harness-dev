{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "dev-graph-registration.schema.json",
  "type": "object",
  "required": ["schema_version", "source_digest", "promotion_receipt", "feature_package_id", "parent_feature", "expected_count", "phase_refs", "binding_intents", "nodes"],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "source_digest": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "promotion_receipt": {"type": "string", "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$)).+$"},
    "feature_package_id": {"type": "string", "pattern": "^feature-package/[A-Za-z0-9._/-]+$"},
    "parent_feature": {"type": "string", "minLength": 1},
    "expected_count": {"const": 13},
    "phase_refs": {"const": ["P01", "P02", "P03", "P04", "P05", "P06", "P07", "P08", "P09", "P10", "P11", "P12", "P13"]},
    "binding_intents": {
      "type": "object",
      "minProperties": 13,
      "maxProperties": 13,
      "additionalProperties": {"type": "string", "enum": ["auto", "beads", "github", "none"]},
      "description": "key=graph_node_id。C02 deterministic checkがkeys exact-set == nodes[].graph_node_idおよびexpected_count == nodes lengthを検査する。mode=bothではautoを拒否する"
    },
    "nodes": {
      "type": "array",
      "minItems": 13,
      "maxItems": 13,
      "description": "exact 13 P01..P13 nodes; validate-system-plan enforces phase exact-set and common parent/package",
      "items": {
        "allOf": [
          {"$ref": "../../dev-graph/schemas/graph-node.schema.json"},
          {
            "type": "object",
            "properties": {
              "artifact_kind": {"const": "task"},
              "artifact_subtypes": {"maxItems": 0},
              "parent_feature": {"type": "string", "minLength": 1},
              "feature_package_id": {"type": "string", "pattern": "^feature-package/[A-Za-z0-9._/-]+$"},
              "phase_ref": {"type": "string", "pattern": "^P(0[1-9]|1[0-3])$"},
              "file_path": {"type": "string", "pattern": "^tasks/.+\\.md$"},
              "status": {"const": "active"},
              "template_id": {"const": "task"},
              "confirmation_status": {"const": "confirmed"},
              "evaluation_status": {"const": "pass"},
              "issue_linkage": {"type": "null"},
              "tracker_binding": {"const": "repo-config-default"},
              "beads_linkage": {"type": "null"},
              "github_project_linkages": {"maxItems": 0},
              "pull_request_linkages": {"maxItems": 0},
              "execution_contexts": {"maxItems": 0},
              "completion_evidence": {
                "type": "object",
                "properties": {
                  "policy": {"enum": ["linked_pr_merged_all", "linked_pr_merged_any"]},
                  "status": {"const": "in_progress"},
                  "source": {"type": "null"},
                  "completed_at": {"type": "null"},
                  "reconciled_at": {"type": "null"},
                  "evidence_refs": {"maxItems": 0}
                }
              },
              "source_lineage": {
                "type": "object",
                "properties": {"origin_kind": {"const": "system-dev-planner"}}
              },
              "implementation_readiness": {
                "type": "object",
                "properties": {"status": {"const": "complete"}}
              }
            }
          }
        ]
      }
    }
  },
  "additionalProperties": false
}
