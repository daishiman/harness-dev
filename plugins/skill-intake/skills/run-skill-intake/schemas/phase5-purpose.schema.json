{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "skill-intake Phase 5 purpose.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["techniques_used", "rounds", "agreement_loop_detected", "true_purpose"],
  "properties": {
    "techniques_used": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string"}
    },
    "rounds": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["question", "answer", "finding"],
        "properties": {
          "question": {"type": "string", "minLength": 1},
          "answer": {"type": "string", "minLength": 1},
          "finding": {"type": "string", "minLength": 1}
        }
      }
    },
    "agreement_loop_detected": {"type": "boolean"},
    "true_purpose": {
      "type": "object",
      "additionalProperties": false,
      "required": ["verb_object", "underlying_motivation"],
      "properties": {
        "verb_object": {"type": "string", "minLength": 1},
        "underlying_motivation": {"type": "string", "minLength": 1},
        "success_signal": {"type": "string"}
      }
    }
  }
}
