    {"id": "P10-notion", "step": 10, "title": "Phase 10: Notion 公開 (指定 page PATCH / fidelity-guard 経由)", "dependsOn": ["P9-finalize"], "delegateType": "skill", "delegateName": "run-notion-intake-publish", "delegateSkill": "run-notion-intake-publish", "resourceIds": [], "fatal_exit_codes": [2, 3]},
