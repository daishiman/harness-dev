      {"column": "契約開始日", "anchor": "本契約の有効期間は", "placeholder": "XX年XX月XX日から", "format": "date_ja_from", "required": true},
      {"column": "契約終了日", "anchor": "本契約の有効期間は", "placeholder": "XX年XX月XX日までの", "format": "date_ja_to", "required": true},
      {"column": "契約期間_年数", "anchor": "までのX年間とする", "placeholder": "X年間", "value_template": "{v}年間", "required": true},
