    ],
    "conditionals": [
      {"column": "業務内容方式", "when": "別紙1に定める", "anchor": "本業務の内容及び範囲は、以下のとおりと", "keep": "別紙"},
      {"column": "業務内容方式", "when": "する", "anchor": "本業務の内容及び範囲は、以下のとおりと", "keep": "本文"},
