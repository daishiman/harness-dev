      {"column": "金額", "anchor": "本業務委託料」という）として", "placeholder": "金XXXX円", "format": "currency_yen", "required": false, "condition": "料金方式==固定金額"},
      {"column": "振込先_銀行名", "anchor": "^銀行名：", "placeholder": "$", "mode": "fill_after_colon", "required": true},
