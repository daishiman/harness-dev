{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "schemaVersion": 1,
  "workflowId": "run-slide-report-generate",
  "skill": "run-slide-report-generate",
  "description": "output_mode(slide/report) を送信前に fail-closed 検証して確定し、意匠/技術コアを共有したまま構成設計→仕様確定ゲート→生成(HTML/決定論 render-slide.cjs/report render-report.js/Codex 画像)→生成後評価(30 種思考法)まで 15 agent を Task name 起動で統率する主オーケストレータ。",
  "phases": [
    {
      "id": "R1-hearing-mode",
      "step": 1,
      "title": "hearing-facilitator で output_mode/reportType/読者/長さ/ビジュアル方針を確定し validate-output-mode.py で送信前値域検証(fail-closed)して下流へ一貫伝播",
      "gate": "C1",
      "dependsOn": [],
      "entryHook": null,
      "exitHook": "validate-output-mode",
      "resourceIds": [
        "ref-resource-map",
        "glue-validate-output-mode",
        "schema-structure",
        "schema-report-structure"
      ],
      "fatal_exit_codes": [
        2
      ]
    },
    {
      "id": "R2-structure-gate",
      "step": 2,
      "title": "確定 mode で structure-designer/report-structure-designer(+d3/data-visualizer/visual-strategist) が構成を設計し structure-validator + validate-structure.js の仕様確定ゲートで P3 進入を制御(PASS→R3 / WARN→承認後 R3 / FAIL→R2 差戻し)",
      "gate": "C2",
      "dependsOn": [
        "R1-hearing-mode"
      ],
      "entryHook": null,
      "exitHook": "validate-structure",
      "resourceIds": [
        "ref-structure-design-rules",
        "ref-report-structure-types",
        "ref-d3-diagram-rules",
        "ref-data-visualization-rules",
        "schema-structure",
        "schema-report-structure",
        "vendor-validate-structure",
        "vendor-workflow-manager"
      ],
      "fatal_exit_codes": []
    },
    {
      "id": "R3-generate-evaluate",
      "step": 3,
      "title": "経路(slide LLM=html-generator / slide 決定論=slide-renderer+render-slide.cjs / report=report-composer+render-report.js(+mermaid-render.js) / 画像明示=ai-image-diagram-producer)で成果物を生成し、slide は layout-optimizer/ui-quality-reviewer + verify-slides.js/evaluate-deck.js/validate-print.js、report は verify-report-runtime.js で899/900/901/1024/1366/1600px+printの実描画bundleを生成し、report-quality-reviewer + validate-report-visual.py がbundle必須で補正/検査する。最後に deck-evaluator の mode-aware 30 種思考法 rubric を最大 3 周 reloop。bundle欠落またはCRITICAL残存はhard-fail",
      "gate": "C3",
      "dependsOn": [
        "R2-structure-gate"
      ],
      "entryHook": null,
      "exitHook": "slide:evaluate-deck | report:validate-report-visual",
      "resourceIds": [
        "ref-html-generation-rules",
        "ref-layout-optimization-rules",
        "ref-ui-quality-checklist",
        "ref-report-quality-checklist",
        "ref-deck-evaluation-rubric",
        "ref-ai-image-pipeline",
        "schema-structure",
        "schema-report-structure",
        "vendor-render-slide",
        "vendor-render-report",
        "vendor-mermaid-render",
        "vendor-build-image-prompts",
        "vendor-generate-images-codex",
        "vendor-build-deck-html",
        "vendor-verify-slides",
        "vendor-evaluate-deck",
        "vendor-validate-print",
        "vendor-verify-report-runtime",
        "glue-validate-report-visual",
        "vendor-validate-ai-image-assets",
        "vendor-workflow-manager"
      ],
      "fatal_exit_codes": [],
      "max_iterations": 3
    }
  ],
