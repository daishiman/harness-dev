      },
      "layout": {
        "viewBox": "0 0 960 540",
        "paddingTop": "4vw",
        "paddingX": "5vw",
        "gap": "1.5vw"
      }
    },

    {
      "id": "slide-004",
      "section": "section-status",
      "slideType": "diagram-prep",
      "purpose": "P-WHL",
      "structure": "S-SYS",
      "content": {
