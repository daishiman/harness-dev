    {
      "id": "slide-005",
      "section": "section-closing",
      "slideType": "slide-highlight",
      "purpose": "P-NUM",
      "structure": "S-SGL",
      "content": {
        "title": "本日のサマリー",
        "value": "40%",
        "label": "案件納期の短縮幅",
        "context": "雛形v3.0適用案件8件の平均値（2026 Q2実績）"
