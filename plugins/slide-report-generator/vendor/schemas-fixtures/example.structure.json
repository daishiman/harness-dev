{
  "$schema": "./structure.schema.json",
  "meta": {
    "title": "AIコンサルティング事業 中間報告",
    "subtitle": "2026年Q2 進捗レビュー",
    "audience": "経営層・事業部長（10名）",
    "durationMinutes": 30,
    "keyMessage": "AI実装支援の標準化により、案件あたり納期を40%短縮できる",
    "language": "ja",
    "presenter": "山田 太郎",
    "version": "1.0.0"
  },

  "theme": {
    "name": "kanagawa-lotus",
    "mode": "light",
    "accentColors": ["accent-blue-vivid", "accent-aqua-vivid"],
    "fontScale": 1.3
