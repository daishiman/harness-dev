      "title": "現状報告",
      "color": "wave-aqua",
      "slides": [3, 4]
    },
    {
      "id": "section-closing",
      "title": "クロージング",
      "color": "sakura-pink",
      "slides": [5]
    }
  ],

  "slides": [
    {
      "id": "slide-001",
      "section": "section-opening",
      "slideType": "slide-hero",
      "purpose": "P-EMO",
      "structure": "S-SGL",
      "content": {
        "title": "AIで仕事を再発明する",
        "subtitle": "2026 Q2 中間報告",
        "icon": "fa-solid fa-rocket"
      },
      "animations": {
        "enter": { "duration": 0.6, "scale": 0.9, "opacity": 0, "ease": "back.out(1.7)" },
        "ease": "back.out(1.7)"
