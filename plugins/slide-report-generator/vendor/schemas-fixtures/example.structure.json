    },

    {
      "id": "slide-002",
      "section": "section-opening",
      "slideType": "slide-message",
      "purpose": "P-CON",
      "structure": "S-SGL",
      "content": {
        "main": "標準化が、品質と速度を両立させる唯一の道である",
        "accent": "accent-blue-vivid",
        "icon": "fa-solid fa-bullseye",
        "subtext": "本日のキーメッセージ"
      },
      "animations": {
        "enter": { "duration": 0.5, "y": 30, "opacity": 0, "ease": "power3.out" }
      }
    },

