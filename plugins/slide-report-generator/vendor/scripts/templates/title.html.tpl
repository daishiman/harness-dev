<section class="slider__item slide-title" data-section="{{section}}" data-slide-type="title" data-index="{{index}}">
  <div class="slider__content">
    <h1>{{title}}</h1>
    {{#subtitle}}<p class="subtitle">{{subtitle}}</p>{{/subtitle}}
    {{#author}}<p class="text-note">{{author}}</p>{{/author}}
  </div>
</section>
