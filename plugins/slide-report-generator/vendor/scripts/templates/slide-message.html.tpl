<section class="slider__item slide-slide-message" data-section="{{section}}" data-slide-type="slide-message" data-index="{{index}}">
  <div class="slider__content">
    {{#icon}}<div class="msg-icon"><i class="{{icon}}" aria-hidden="true"></i></div>{{/icon}}
    <p class="main-message">{{main}}</p>
    {{#subtext}}<p class="text-note">{{subtext}}</p>{{/subtext}}
  </div>
</section>
