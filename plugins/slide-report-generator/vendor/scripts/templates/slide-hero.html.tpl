<section class="slider__item slide-slide-hero" data-section="{{section}}" data-slide-type="slide-hero" data-index="{{index}}">
  <div class="slider__content">
    {{#icon}}<div class="hero-icon"><i class="{{icon}}" aria-hidden="true"></i></div>{{/icon}}
    <h1>{{title}}</h1>
    {{#subtitle}}<p class="hero-sub">{{subtitle}}</p>{{/subtitle}}
  </div>
</section>
