<section class="slider__item slide-slide-title" data-section="{{section}}" data-slide-type="slide-title" data-index="{{index}}">
  <div class="slider__content">
    <h1>{{title}}</h1>
    {{#subtitle}}<p class="subtitle">{{subtitle}}</p>{{/subtitle}}
    {{#section_number}}<p class="text-note">Section {{section_number}}</p>{{/section_number}}
  </div>
</section>
