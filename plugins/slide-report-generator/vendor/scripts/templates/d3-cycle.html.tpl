<section class="slider__item slide-d3 d3-cycle" data-section="{{section}}" data-slide-type="d3-cycle" data-index="{{index}}" data-d3-component="cycle" data-d3-config={{configJson}}>
  <div class="slider__content">
    <h2>{{title}}</h2>
    <div class="d3-mount" id="d3-mount-{{index}}"></div>
    <script type="application/json" data-d3-mount data-d3-target="d3-mount-{{index}}" data-d3-component="cycle">{{{configJson}}}</script>
  </div>
</section>
