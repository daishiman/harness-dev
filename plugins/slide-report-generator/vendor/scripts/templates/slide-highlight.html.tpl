<section class="slider__item slide-slide-highlight" data-section="{{section}}" data-slide-type="slide-highlight" data-index="{{index}}">
  <div class="slider__content">
    {{#title}}<h2>{{title}}</h2>{{/title}}
    <div class="highlight-num">{{value}}</div>
    <div class="highlight-label">{{label}}</div>
    {{#context}}<p class="text-note">{{context}}</p>{{/context}}
  </div>
</section>
