<section class="slider__item slide-code-compare" data-section="{{section}}" data-slide-type="code-compare" data-index="{{index}}">
  <div class="slider__content">
    <h2>{{title}}</h2>
    <div class="code-compare">
      <div class="code-panel code-panel--before">
        <div class="code-panel__header">{{before.title}}</div>
        <pre><code>{{before.code}}</code></pre>
      </div>
      <div class="code-panel code-panel--after">
        <div class="code-panel__header">{{after.title}}</div>
        <pre><code>{{after.code}}</code></pre>
      </div>
    </div>
  </div>
</section>
