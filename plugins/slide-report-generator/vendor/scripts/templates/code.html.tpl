<section class="slider__item slide-code" data-section="{{section}}" data-slide-type="code" data-index="{{index}}">
  <div class="slider__content">
    <h2>{{title}}</h2>
    <pre class="code-block"><code>{{code}}</code></pre>
    {{#note}}<p class="text-note">{{note}}</p>{{/note}}
  </div>
</section>
