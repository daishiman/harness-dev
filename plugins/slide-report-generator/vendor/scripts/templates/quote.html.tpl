<section class="slider__item slide-quote" data-section="{{section}}" data-slide-type="quote" data-index="{{index}}">
  <div class="slider__content">
    {{#title}}<h2>{{title}}</h2>{{/title}}
    <blockquote>{{quote}}</blockquote>
    {{#author}}<cite>— {{author}}</cite>{{/author}}
  </div>
</section>
