<section class="slider__item slide-message" data-section="{{section}}" data-slide-type="message" data-index="{{index}}">
  <div class="slider__content">
    {{#title}}<h2>{{title}}</h2>{{/title}}
    <p class="main-message">{{message}}</p>
    {{#note}}<p class="text-note">{{note}}</p>{{/note}}
  </div>
</section>
