<section class="slider__item slide-highlight" data-section="{{section}}" data-slide-type="highlight" data-index="{{index}}">
  <div class="slider__content">
    <div class="highlight-num">{{number}}</div>
    <div class="highlight-label">{{label}}</div>
    {{#note}}<p class="text-note">{{note}}</p>{{/note}}
  </div>
</section>
