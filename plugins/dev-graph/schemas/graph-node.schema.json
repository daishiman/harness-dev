            "type": "string",
            "format": "date-time"
          },
          "released_at": {
            "type": [
              "string",
              "null"
            ],
            "format": "date-time"
          }
        }
      },
      "description": "git common dirのephemeral lease registryからdefault branch側で収束したdurable projection。worktree絶対pathやsession secretは保持しない。"
    },
    "completion_evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "policy",
        "status",
        "source",
        "completed_at",
        "reconciled_at",
        "evidence_refs"
      ],
