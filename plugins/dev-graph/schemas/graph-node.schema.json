      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "complete",
            "incomplete",
            "not_applicable"
          ]
        },
        "missing_sections": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "checked_at": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        }
      },
      "additionalProperties": false,
      "description": "template-contract.jsonの必須field/section、placeholder、conditional template、参照解決を検査した実装着手準備状態"
    }
  },
