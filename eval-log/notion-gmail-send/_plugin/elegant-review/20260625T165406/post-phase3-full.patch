+    print(f"plan_hash   : {plan['plan_hash']}")
+    print(f"第1段 計画送信単位 = 本文true({len(bodies)}) × 宛先true({len(recips)}) = {first_stage}")
+    print(f"  宛先 = 送信対象✅かつ送らない☐の dedup後 {len(recips)} 件 "
