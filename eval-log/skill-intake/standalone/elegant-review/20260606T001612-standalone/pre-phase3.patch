+    if m:
+        return m.group(0).lower()
+    # 2) スラグ-id 形式: 最後のダッシュ以降の末尾トークンが 32hex なら採用
+    last = seg.split('-')[-1]
+    if re.fullmatch(r'[0-9a-fA-F]{32}', last):
+        h = last.lower()
+        return f'{h[0:8]}-{h[8:12]}-{h[12:16]}-{h[16:20]}-{h[20:32]}'
+    return None
