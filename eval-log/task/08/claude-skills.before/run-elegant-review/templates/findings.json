  "variable_abstraction": {
    "policy": "具体値は再利用成果物に直書きせず、変数と既定値へ戻す",
    "variables": [
      {
        "name": "{{PROJECT_ROOT}}",
        "meaning": "対象プロジェクトのルート",
        "example_value": "/path/to/project",
        "default": "実行時 cwd",
        "required": true,
        "not_applicable_when": "対象が単一ファイルで、相対参照を生成しない場合"
      },
      {
        "name": "{{KIT_ROOT}}",
        "meaning": "creator-kit のルート",
        "example_value": "{{PROJECT_ROOT}}/creator-kit",
        "default": "{{PROJECT_ROOT}}/creator-kit",
        "required": true,
        "not_applicable_when": "creator-kit 外の単独レビューで kit 成果物を生成しない場合"
      },
      {
        "name": "{{DOC_ROOT}}",
        "meaning": "参照設計書のルート",
        "example_value": "{{PROJECT_ROOT}}/doc",
        "default": "{{PROJECT_ROOT}}/doc",
        "required": false,
        "not_applicable_when": "設計書由来ではない対象をレビューする場合"
      },
      {
        "name": "{{SOURCE_CANONICAL_PATH}}",
        "meaning": "source_trace で正本として扱うパスまたは URL",
        "example_value": "doc/spec.md",
        "default": "internal",
        "required": false,
        "not_applicable_when": "根拠が会話内指定のみで外部正本を持たない場合"
      },
      {
        "name": "{{runtime_shell}}",
        "meaning": "実行時に使う shell",
        "example_value": "bash",
        "default": "bash|powershell",
        "required": false,
        "not_applicable_when": "実行コマンドを生成しない場合"
      },
      {
        "name": "{{python_cmd}}",
        "meaning": "Python 起動コマンド",
        "example_value": "python3",
        "default": "python3|python",
        "required": false,
        "not_applicable_when": "Python スクリプトを呼ばない場合"
      },
      {
        "name": "{{rubric_id}}",
        "meaning": "評価基準ID",
        "example_value": "skill-design",
        "default": "skill-design",
        "required": false,
        "not_applicable_when": "rubric を扱わない対象の場合"
      },
      {
        "name": "{{rubric_version}}",
        "meaning": "評価基準バージョン",
        "example_value": "1.0.0",
        "default": "1.0.0",
        "required": false,
        "not_applicable_when": "rubric を扱わない対象の場合"
      },
      {
        "name": "{{execution_context}}",
        "meaning": "script実行コンテキスト A-E",
        "example_value": "C",
        "default": "C",
        "required": false,
        "not_applicable_when": "script / hook / CI を扱わない場合"
      },
      {
        "name": "{{write_scope}}",
        "meaning": "script が書き込める範囲",
        "example_value": "none|output-dir",
        "default": "none|output-dir",
        "required": false,
        "not_applicable_when": "script を扱わない場合"
      },
      {
        "name": "{{hook_event}}",
        "meaning": "Hookイベント名",
        "example_value": "PreToolUse",
        "default": "PreToolUse",
        "required": false,
        "not_applicable_when": "hook を扱わない場合"
      },
      {
        "name": "{{eval_log_path}}",
        "meaning": "評価ログ出力先",
        "example_value": "eval-log/core/YYYY-MM-DD-score.jsonl",
        "default": "eval-log/core/YYYY-MM-DD-score.jsonl",
        "required": false,
        "not_applicable_when": "評価ログを生成しない場合"
      },
      {
        "name": "{{SCRIPT_ROOT}}",
        "meaning": "script 配置ルート",
        "example_value": "{{KIT_ROOT}}/scripts",
        "default": "{{KIT_ROOT}}/scripts",
        "required": false,
        "not_applicable_when": "script を呼ばない場合"
      }
    ],
    "source_trace": [
      {
        "concrete_value": "...",
        "variable": "{{...}}",
        "source_tier": "internal",
        "trace_evidence": "..."
      }
    ]
  },
  "four_condition_gates": {
    "C1_consistency": {
      "result": "PASS",
      "evidence": "{{gate_evidence}}"
    },
    "C2_completeness": {
      "result": "PASS",
      "evidence": "{{gate_evidence}}"
    },
    "C3_coherence": {
      "result": "PASS",
      "evidence": "{{gate_evidence}}"
    },
    "C4_dependency": {
      "result": "PASS",
      "evidence": "{{gate_evidence}}"
    }
  },
  "paradigm_coverage": {
    "expected": 30,
    "covered": 30,
    "missing_paradigms": []
  },
  "pattern_ref_candidates": [
    {
      "pattern_ref": "{{pattern_id}}",
      "reason": "...",
      "reuse_surface": "template | rubric | lint | hook | reference | manifest | runbook | none",
      "negative_case": "{{when_not_to_apply}}"
    }
  ],
  "new_patterns": [
    {
      "name": "<candidate-name>",
      "source_paradigms": [
        "meta",
        "analogy"
      ],
      "applicability": "...",
      "negative_cases": [
        "..."
      ]
    }
  ],
  "mass_production_risk": {
    "trigger_overlap": "low | medium | high",
    "naming_collision": "low | medium | high",
    "rubric_sprawl": "low | medium | high",
    "notes": "..."
  },
  "total_score": 0.0,
  "completion": {
    "all_pass": true,
    "next_action": "done"
  },
  "issue_template": {
    "severity": "low",
    "condition": "C1",
    "description": "{{finding_description}}",
    "suggested_fix": "{{suggested_fix}}",
    "finding_scope": "target-specific",
    "source_tier": "internal",
    "trace_evidence": "{{trace_evidence}}",
    "migration_bucket": "none",
    "reuse_surface": "none",
    "runtime_variant": "any",
    "dependency_assumption": "{{dependency_assumption}}",
    "negative_case": "{{negative_case}}",
    "re_audit_trigger": "none",
    "suggested_fix_template": "{{suggested_fix_template}}"
  }
}
