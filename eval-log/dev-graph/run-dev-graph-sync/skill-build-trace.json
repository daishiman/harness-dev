  "design_model": {
    "intent": "tracker_binding別のauthorityに従いローカルtask graphとBeadsまたはGitHub Issues/PRを同期し、Projects Statusはローカルから一方向投影、merged evidenceとworktree eventはdefault branch側task仕様へ収束した状態になっている",
    "contract": "同期レポート (Issue取込/反映、Project item add/edit、project/field別snapshot、manual conflict、pending retry、tombstone件数)。--dry-run時は外部write 0件の差分preview",
    "boundary": "入力=ローカルgraph、repo-local GitHub設定、GitHub Issues/Projects v2/出力=双方向反映済みgraph、issue_linkage、github_project_linkages、同期ledger。追加token管理と環境固有node IDの設定正本化はしない。ローカルpromotionをGitHub部分失敗でrollbackせずpending_retry化する。close/deleteはtombstone/status遷移としgraph_node_idを維持する",
    "execution": "plugins/dev-graph/skills/run-dev-graph-sync/SKILL.md + declared script_refs/prompts",
    "feedback": "frontmatter feedback_contract + DEV_GRAPH_ROOT goal-seek evidence"
  },
